---

<div class="fixed inset-0 block w-full h-full z-50">
  <canvas class="block w-full h-full touch-pan-y" id="canvas"></canvas>
</div>

<script>
  import * as THREE from "three";
  import { Modelo } from "./Modelo";

  const canvas = document.getElementById("canvas") as HTMLCanvasElement;
  const wrapper = canvas.parentElement as HTMLDivElement;

  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
    alpha: true,
  });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  const scene = new THREE.Scene();

  const camera = new THREE.PerspectiveCamera(
    60,
    wrapper.clientWidth / wrapper.clientHeight,
    0.1,
    200,
  );
  camera.position.z = 3;

  const ambientLight = new THREE.AmbientLight(0xffffff, 10);
  scene.add(ambientLight);

  const directionalLight = new THREE.DirectionalLight(0xffffff, 8.5);
  directionalLight.position.set(2, 3, 4);
  scene.add(directionalLight);

  const modelPivot = new THREE.Group();
  scene.add(modelPivot);

  const model = new Modelo((object) => modelPivot.add(object));

  let isDragging = false;
  let prevX = 0,
    prevY = 0;

  const onPointerDown = (e: PointerEvent) => {
    isDragging = true;
    prevX = e.clientX;
    prevY = e.clientY;
  };
  const onPointerMove = (e: PointerEvent) => {
    if (!isDragging) return;
    const dx = e.clientX - prevX;
    modelPivot.rotation.y += dx * 0.01;
    prevX = e.clientX;
  };
  const onPointerEnd = () => {
    isDragging = false;
  };

  canvas.addEventListener("pointerdown", onPointerDown);
  canvas.addEventListener("pointermove", onPointerMove);
  canvas.addEventListener("pointerup", onPointerEnd);
  canvas.addEventListener("pointerleave", onPointerEnd);
  canvas.addEventListener("pointercancel", onPointerEnd);

  let targetCameraY = 0;
  let modelRotationX = 0;
  const onScroll = () => {
    targetCameraY = -window.scrollY * 0.005;
    modelRotationX = window.scrollY * 0.001;
  };
  window.addEventListener("scroll", onScroll);

  let lastTime = performance.now();

  const resizeObserver = new ResizeObserver(() => {
    const width = wrapper.clientWidth;
    const height = wrapper.clientHeight;
    camera.aspect = width / height;
    camera.updateProjectionMatrix();
    renderer.setSize(width, height, false);
  });

  resizeObserver.observe(wrapper);

  renderer.setSize(wrapper.clientWidth, wrapper.clientHeight, false);

  renderer.setAnimationLoop(() => {
    const now = performance.now();
    const delta = (now - lastTime) / 1000;
    lastTime = now;
    camera.position.y += targetCameraY - camera.position.y;
    // modelPivot.rotation.x += modelRotationX - modelPivot.rotation.x;
    camera.lookAt(0, camera.position.y, 0);
    model.update(delta);
    renderer.render(scene, camera);
  });

  document.addEventListener(
    "astro:before-swap",
    () => {
      canvas.removeEventListener("pointerdown", onPointerDown);
      canvas.removeEventListener("pointermove", onPointerMove);
      canvas.removeEventListener("pointerup", onPointerEnd);
      canvas.removeEventListener("pointerleave", onPointerEnd);
      canvas.removeEventListener("pointercancel", onPointerEnd);
      window.removeEventListener("scroll", onScroll);
      resizeObserver.disconnect();
      renderer.setAnimationLoop(null);
      renderer.dispose();
    },
    { once: true },
  );
</script>
